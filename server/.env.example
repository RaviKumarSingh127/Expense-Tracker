NODE_ENV=development
PORT=5000

# MongoDB — get free cluster at mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/flowfin?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_string_here
JWT_REFRESH_SECRET=your_different_64_char_random_string_here

# Google Gemini AI — get key at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Redis (optional) — get free instance at redis.io/try-free
REDIS_URL=redis://localhost:6379

# Cloudinary (optional, for receipt images) — cloudinary.com
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Logging
LOG_LEVEL=info
